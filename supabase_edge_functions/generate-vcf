// supabase/functions/generate-vcf/index.ts

import { serve } from "https://deno.land/std@0.177.0/http/server.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
);

serve(async () => {
    try {
        const today = new Date();
        const eatOffset = 3 * 60 * 60 * 1000;
        const eatDate = new Date(today.getTime() + eatOffset);
        const dateStr = eatDate.toISOString().split('T')[0];

        // Get all active contacts
        const { data: contacts, error: contactsError } = await supabase
            .from('contacts')
            .select('phone_number, country_code, country_name')
            .eq('is_active', true)
            .order('added_at', { ascending: true });

        if (contactsError) throw contactsError;

        // Generate VCF content
        let vcf = `BEGIN:VCARD\nVERSION:3.0\n`;
        contacts.forEach((contact, index) => {
            vcf += `FN:StatusStar${index + 1}\n`;
            vcf += `TEL:${contact.phone_number.replace(/^\+/, '')}\n`;
            vcf += `END:VCARD\n`;
        });

        // Upload to Supabase Storage
        const fileName = `daily/vcf_${dateStr}.vcf`;
        const { data: uploadData, error: uploadError } = await supabase
            .storage
            .from('vcf_files')
            .upload(fileName, vcf, {
                contentType: 'text/vcard',
                cacheControl: '3600'
            });

        if (uploadError) throw uploadError;

        // Get public URL
        const { data: urlData } = supabase
            .storage
            .from('vcf_files')
            .getPublicUrl(fileName);

        // Record generation
        const { error: genError } = await supabase
            .from('vcf_generations')
            .insert({
                generation_date: dateStr,
                file_url: fileName,
                file_size: vcf.length,
                contact_count: contacts.length,
                status: 'completed'
            });

        if (genError) throw genError;

        // Update last_included_date for all active contacts
        const { error: updateError } = await supabase
            .from('contacts')
            .update({ last_included_date: dateStr })
            .eq('is_active', true);

        if (updateError) throw updateError;

        return new Response(JSON.stringify({
            success: true,
            message: 'VCF generated successfully',
            contactCount: contacts.length,
            date: dateStr,
            url: urlData.publicUrl
        }), {
            headers: { 'Content-Type': 'application/json' }
        });

    } catch (error) {
        return new Response(JSON.stringify({
            success: false,
            error: error.message
        }), {
            status: 500,
            headers: { 'Content-Type': 'application/json' }
        });
    }
});
