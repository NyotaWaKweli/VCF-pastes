// supabase/functions/check-number/index.ts

import { serve } from "https://deno.land/std@0.177.0/http/server.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

// ─── ENVIRONMENT VARIABLES ───
// These are automatically injected by Supabase
const supabaseUrl = Deno.env.get('VITE_SUPABASE_URL')!;
const supabaseAnonKey = Deno.env.get('VITE_SUPABASE_PUBLISHABLE_KEYS')!;

const supabase = createClient(supabaseUrl, supabaseAnonKey);

serve(async (req) => {
    try {
        const { phoneNumber, deviceId } = await req.json();

        if (!phoneNumber || !deviceId) {
            return new Response(JSON.stringify({
                success: false,
                error: 'Phone number and device ID required'
            }), { status: 400, headers: { 'Content-Type': 'application/json' } });
        }

        // Check rate limit
        const { data: rateCheck, error: rateError } = await supabase
            .rpc('check_rate_limit', {
                p_device_id: deviceId,
                p_action: 'check',
                p_max_per_day: 5,
                p_cooldown_minutes: 5
            });

        if (rateError) {
            return new Response(JSON.stringify({
                success: false,
                error: rateError.message
            }), { status: 500, headers: { 'Content-Type': 'application/json' } });
        }

        if (!rateCheck) {
            return new Response(JSON.stringify({
                success: false,
                error: 'Rate limit exceeded',
                limit: true
            }), { status: 429, headers: { 'Content-Type': 'application/json' } });
        }

        // Clean phone number
        const cleanPhone = phoneNumber.replace(/^\+/, '');

        // Get number status
        const { data: status, error: statusError } = await supabase
            .from('number_status')
            .select('status, last_included, added_at')
            .eq('phone_number', cleanPhone)
            .maybeSingle();

        if (statusError && statusError.code !== 'PGRST116') {
            throw statusError;
        }

        // Record visit
        await supabase.rpc('increment_visit');

        return new Response(JSON.stringify({
            success: true,
            status: status?.status || 'not_found',
            lastIncluded: status?.last_included || null,
            addedAt: status?.added_at || null
        }), {
            headers: { 'Content-Type': 'application/json' }
        });

    } catch (error) {
        return new Response(JSON.stringify({
            success: false,
            error: error.message
        }), {
            status: 500,
            headers: { 'Content-Type': 'application/json' }
        });
    }
});
