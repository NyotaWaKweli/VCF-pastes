// supabase/functions/submit-contact/index.ts

import { serve } from "https://deno.land/std@0.177.0/http/server.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

// ─── ENVIRONMENT VARIABLES ───
const supabaseUrl = Deno.env.get('VITE_SUPABASE_URL')!;
const supabaseAnonKey = Deno.env.get('VITE_SUPABASE_PUBLISHABLE_KEYS')!;

const supabase = createClient(supabaseUrl, supabaseAnonKey);

serve(async (req) => {
    try {
        const { subject, message, email, countryCode, countryName, deviceId } = await req.json();

        if (!subject || !message || !email) {
            return new Response(JSON.stringify({
                success: false,
                error: 'Subject, message, and email are required'
            }), { status: 400, headers: { 'Content-Type': 'application/json' } });
        }

        // Validate email format
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
            return new Response(JSON.stringify({
                success: false,
                error: 'Invalid email format'
            }), { status: 400, headers: { 'Content-Type': 'application/json' } });
        }

        // Check rate limit for contact messages
        const { data: rateCheck, error: rateError } = await supabase
            .rpc('check_rate_limit', {
                p_device_id: deviceId || 'anonymous',
                p_action: 'contact',
                p_max_per_day: 2,
                p_cooldown_minutes: 10
            });

        if (rateError) {
            return new Response(JSON.stringify({
                success: false,
                error: rateError.message
            }), { status: 500, headers: { 'Content-Type': 'application/json' } });
        }

        if (!rateCheck) {
            return new Response(JSON.stringify({
                success: false,
                error: 'Rate limit exceeded for contact messages',
                limit: true
            }), { status: 429, headers: { 'Content-Type': 'application/json' } });
        }

        // Get user agent from request headers
        const userAgent = req.headers.get('user-agent') || '';

        // Insert contact message
        const { data, error } = await supabase
            .from('contact_messages')
            .insert({
                subject,
                message,
                email,
                country_code: countryCode || '',
                country_name: countryName || '',
                device_id: deviceId || 'anonymous',
                device_info: userAgent
            })
            .select();

        if (error) throw error;

        return new Response(JSON.stringify({
            success: true,
            message: 'Message sent successfully',
            id: data[0]?.id
        }), {
            headers: { 'Content-Type': 'application/json' }
        });

    } catch (error) {
        return new Response(JSON.stringify({
            success: false,
            error: error.message
        }), {
            status: 500,
            headers: { 'Content-Type': 'application/json' }
        });
    }
});
