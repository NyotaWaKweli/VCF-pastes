-- Enable UUID extension if not already enabled
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- =============================================
-- TABLES
-- =============================================

-- 1. Contacts Table
CREATE TABLE IF NOT EXISTS contacts (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    phone_number TEXT NOT NULL,
    country_code TEXT NOT NULL,
    country_name TEXT NOT NULL,
    device_id TEXT NOT NULL,
    added_at TIMESTAMP DEFAULT NOW(),
    last_included_date DATE,
    is_active BOOLEAN DEFAULT TRUE,
    source TEXT DEFAULT 'manual',
    UNIQUE(phone_number, device_id)
);

-- Indexes for contacts
CREATE INDEX IF NOT EXISTS idx_contacts_phone_number ON contacts(phone_number);
CREATE INDEX IF NOT EXISTS idx_contacts_device_id ON contacts(device_id);
CREATE INDEX IF NOT EXISTS idx_contacts_added_at ON contacts(added_at);
CREATE INDEX IF NOT EXISTS idx_contacts_last_included ON contacts(last_included_date);
CREATE INDEX IF NOT EXISTS idx_contacts_active ON contacts(is_active);

-- 2. Daily Visits Table
CREATE TABLE IF NOT EXISTS daily_visits (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    visit_date DATE UNIQUE NOT NULL,
    visit_count INTEGER DEFAULT 0,
    unique_devices INTEGER DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- Index for daily_visits
CREATE INDEX IF NOT EXISTS idx_daily_visits_date ON daily_visits(visit_date);

-- 3. VCF Generations Table
CREATE TABLE IF NOT EXISTS vcf_generations (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    generated_at TIMESTAMP DEFAULT NOW(),
    generation_date DATE UNIQUE NOT NULL,
    file_url TEXT,
    file_size INTEGER,
    contact_count INTEGER DEFAULT 0,
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed'))
);

-- Indexes for vcf_generations
CREATE INDEX IF NOT EXISTS idx_vcf_generations_date ON vcf_generations(generation_date);
CREATE INDEX IF NOT EXISTS idx_vcf_generations_status ON vcf_generations(status);

-- 4. Rate Limits Table
CREATE TABLE IF NOT EXISTS rate_limits (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    device_id TEXT NOT NULL,
    action TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT NOW(),
    ip_address TEXT,
    user_agent TEXT
);

-- Indexes for rate_limits
CREATE INDEX IF NOT EXISTS idx_rate_limits_device_action ON rate_limits(device_id, action);
CREATE INDEX IF NOT EXISTS idx_rate_limits_created_at ON rate_limits(created_at);
CREATE INDEX IF NOT EXISTS idx_rate_limits_device_action_date ON rate_limits(device_id, action, created_at);

-- 5. Feedback Table
CREATE TABLE IF NOT EXISTS feedback (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    message TEXT NOT NULL,
    email TEXT,
    country_code TEXT,
    country_name TEXT,
    device_id TEXT,
    device_info TEXT,
    browser_info TEXT,
    screen_size TEXT,
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'read', 'resolved')),
    created_at TIMESTAMP DEFAULT NOW(),
    resolved_at TIMESTAMP
);

-- Indexes for feedback
CREATE INDEX IF NOT EXISTS idx_feedback_status ON feedback(status);
CREATE INDEX IF NOT EXISTS idx_feedback_created_at ON feedback(created_at);
CREATE INDEX IF NOT EXISTS idx_feedback_email ON feedback(email);

-- 6. Contact Messages Table
CREATE TABLE IF NOT EXISTS contact_messages (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    subject TEXT NOT NULL,
    message TEXT NOT NULL,
    email TEXT NOT NULL,
    country_code TEXT,
    country_name TEXT,
    device_id TEXT,
    device_info TEXT,
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'read', 'replied')),
    created_at TIMESTAMP DEFAULT NOW(),
    replied_at TIMESTAMP
);

-- Indexes for contact_messages
CREATE INDEX IF NOT EXISTS idx_contact_messages_status ON contact_messages(status);
CREATE INDEX IF NOT EXISTS idx_contact_messages_created_at ON contact_messages(created_at);
CREATE INDEX IF NOT EXISTS idx_contact_messages_email ON contact_messages(email);

-- =============================================
-- VIEWS
-- =============================================

-- 1. Number Status View
CREATE OR REPLACE VIEW number_status AS
SELECT 
    c.phone_number,
    c.country_code,
    c.country_name,
    c.device_id,
    CASE 
        WHEN c.last_included_date = CURRENT_DATE AT TIME ZONE 'Africa/Nairobi' THEN 'found'
        WHEN c.added_at::DATE >= CURRENT_DATE AT TIME ZONE 'Africa/Nairobi' AND c.last_included_date IS NULL THEN 'pending'
        WHEN c.added_at::DATE >= CURRENT_DATE AT TIME ZONE 'Africa/Nairobi' AND c.last_included_date < CURRENT_DATE AT TIME ZONE 'Africa/Nairobi' THEN 'pending'
        ELSE 'not_found'
    END AS status,
    c.last_included_date AS last_included,
    c.added_at AS added_at,
    c.is_active
FROM contacts c
WHERE c.is_active = TRUE;

-- 2. Daily Stats View
CREATE OR REPLACE VIEW daily_stats AS
SELECT 
    dv.visit_date,
    dv.visit_count,
    dv.unique_devices,
    COALESCE(vg.contact_count, 0) AS vcf_contact_count,
    COALESCE(
        (SELECT COUNT(*) FROM contacts WHERE added_at::DATE = dv.visit_date), 0
    ) AS new_users,
    COALESCE(
        (SELECT COUNT(*) FROM rate_limits WHERE DATE(created_at) = dv.visit_date AND action = 'check'), 0
    ) AS total_checks,
    COALESCE(
        (SELECT COUNT(*) FROM rate_limits WHERE DATE(created_at) = dv.visit_date AND action = 'add'), 0
    ) AS total_adds
FROM daily_visits dv
LEFT JOIN vcf_generations vg ON vg.generation_date = dv.visit_date
WHERE dv.visit_date >= CURRENT_DATE - INTERVAL '30 days'
ORDER BY dv.visit_date DESC;

-- 3. Country Stats View
CREATE OR REPLACE VIEW country_stats AS
SELECT 
    country_code,
    country_name,
    COUNT(*) AS total_users,
    COUNT(*) FILTER (WHERE last_included_date = CURRENT_DATE AT TIME ZONE 'Africa/Nairobi') AS active_today
FROM contacts
WHERE is_active = TRUE
GROUP BY country_code, country_name
ORDER BY total_users DESC;

-- =============================================
-- FUNCTIONS
-- =============================================

-- 1. Update Updated At Trigger Function
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$;

-- 2. Increment Visit Count
CREATE OR REPLACE FUNCTION increment_visit()
RETURNS INTEGER
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    today_date DATE := CURRENT_DATE AT TIME ZONE 'Africa/Nairobi';
    current_count INTEGER;
BEGIN
    INSERT INTO daily_visits (visit_date, visit_count, unique_devices)
    VALUES (today_date, 1, 1)
    ON CONFLICT (visit_date) 
    DO UPDATE SET 
        visit_count = daily_visits.visit_count + 1,
        updated_at = NOW()
    RETURNING visit_count INTO current_count;
    
    RETURN current_count;
END;
$$;

-- 3. Check Rate Limit
CREATE OR REPLACE FUNCTION check_rate_limit(
    p_device_id TEXT,
    p_action TEXT,
    p_max_per_day INTEGER DEFAULT 5,
    p_cooldown_minutes INTEGER DEFAULT 5
)
RETURNS BOOLEAN
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    v_count INTEGER;
    v_today DATE := CURRENT_DATE;
    v_cooldown_time TIMESTAMP := NOW() - (p_cooldown_minutes || ' minutes')::INTERVAL;
BEGIN
    -- Check if user has exceeded daily limit
    SELECT COUNT(*) INTO v_count
    FROM rate_limits
    WHERE device_id = p_device_id
    AND action = p_action
    AND DATE(created_at) = v_today;
    
    IF v_count >= p_max_per_day THEN
        RETURN FALSE;
    END IF;
    
    -- Check cooldown
    IF EXISTS (
        SELECT 1 FROM rate_limits
        WHERE device_id = p_device_id
        AND action = p_action
        AND created_at > v_cooldown_time
        AND DATE(created_at) = v_today
    ) THEN
        RETURN FALSE;
    END IF;
    
    -- Insert rate limit record
    INSERT INTO rate_limits (device_id, action, created_at)
    VALUES (p_device_id, p_action, NOW());
    
    RETURN TRUE;
END;
$$;

-- 4. Get Today's VCF
CREATE OR REPLACE FUNCTION get_todays_vcf()
RETURNS TABLE (
    phone_number TEXT,
    country_code TEXT,
    country_name TEXT
)
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
BEGIN
    RETURN QUERY
    SELECT c.phone_number, c.country_code, c.country_name
    FROM contacts c
    WHERE c.last_included_date = CURRENT_DATE AT TIME ZONE 'Africa/Nairobi'
    AND c.is_active = TRUE
    ORDER BY c.added_at ASC;
END;
$$;

-- 5. Add Number to VCF
CREATE OR REPLACE FUNCTION add_number_to_vcf(
    p_phone_number TEXT,
    p_country_code TEXT,
    p_country_name TEXT,
    p_device_id TEXT
)
RETURNS JSON
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    v_result JSON;
    v_today DATE := CURRENT_DATE AT TIME ZONE 'Africa/Nairobi';
    v_tomorrow DATE := v_today + INTERVAL '1 day';
BEGIN
    -- Check if number exists from this device
    IF EXISTS (
        SELECT 1 FROM contacts
        WHERE phone_number = p_phone_number
        AND device_id = p_device_id
        AND is_active = TRUE
    ) THEN
        -- Update last included date for tomorrow
        UPDATE contacts
        SET last_included_date = v_tomorrow
        WHERE phone_number = p_phone_number
        AND device_id = p_device_id
        AND is_active = TRUE;
        
        RETURN json_build_object(
            'success', TRUE,
            'status', 'updated',
            'message', 'Number updated for tomorrow'
        );
    END IF;
    
    -- Check if number exists from another device
    IF EXISTS (
        SELECT 1 FROM contacts
        WHERE phone_number = p_phone_number
        AND is_active = TRUE
    ) THEN
        RETURN json_build_object(
            'success', FALSE,
            'status', 'duplicate_global',
            'message', 'This number is already registered'
        );
    END IF;
    
    -- Insert new contact
    INSERT INTO contacts (
        phone_number,
        country_code,
        country_name,
        device_id,
        last_included_date,
        added_at
    ) VALUES (
        p_phone_number,
        p_country_code,
        p_country_name,
        p_device_id,
        v_tomorrow,
        NOW()
    );
    
    RETURN json_build_object(
        'success', TRUE,
        'status', 'added',
        'message', 'Number added for tomorrow'
    );
EXCEPTION
    WHEN unique_violation THEN
        RETURN json_build_object(
            'success', FALSE,
            'status', 'duplicate',
            'message', 'Number already exists'
        );
    WHEN OTHERS THEN
        RETURN json_build_object(
            'success', FALSE,
            'status', 'error',
            'message', SQLERRM
        );
END;
$$;

-- 6. Clean Old Rate Limits
CREATE OR REPLACE FUNCTION clean_old_rate_limits()
RETURNS INTEGER
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    v_deleted INTEGER;
BEGIN
    WITH deleted AS (
        DELETE FROM rate_limits
        WHERE created_at < NOW() - INTERVAL '30 days'
        RETURNING id
    )
    SELECT COUNT(*) INTO v_deleted FROM deleted;
    
    RETURN v_deleted;
END;
$$;

