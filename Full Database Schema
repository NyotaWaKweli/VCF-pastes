-- Update updated_at on daily_visits
DROP TRIGGER IF EXISTS update_daily_visits_updated_at ON daily_visits;
CREATE TRIGGER update_daily_visits_updated_at
    BEFORE UPDATE ON daily_visits
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

