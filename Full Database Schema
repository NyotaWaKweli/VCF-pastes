-- Enable RLS on all tables
ALTER TABLE contacts ENABLE ROW LEVEL SECURITY;
ALTER TABLE daily_visits ENABLE ROW LEVEL SECURITY;
ALTER TABLE vcf_generations ENABLE ROW LEVEL SECURITY;
