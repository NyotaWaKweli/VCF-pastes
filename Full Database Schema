-- Contacts Policies
DROP POLICY IF EXISTS "Anyone can read active contacts" ON contacts;
CREATE POLICY "Anyone can read active contacts"
ON contacts FOR SELECT
USING (is_active = TRUE);

DROP POLICY IF EXISTS "Anyone can insert contacts" ON contacts;
CREATE POLICY "Anyone can insert contacts"
ON contacts FOR INSERT
WITH CHECK (
    check_rate_limit(
        current_setting('app.device_id', TRUE),
        'add',
        2
    ) = TRUE
);

DROP POLICY IF EXISTS "Service role can update contacts" ON contacts;
CREATE POLICY "Service role can update contacts"
ON contacts FOR UPDATE
USING (auth.role() = 'service_role')
WITH CHECK (auth.role() = 'service_role');

-- Daily Visits Policies
DROP POLICY IF EXISTS "Anyone can read visits" ON daily_visits;
CREATE POLICY "Anyone can read visits"
ON daily_visits FOR SELECT
USING (true);

DROP POLICY IF EXISTS "Service role can manage visits" ON daily_visits;
CREATE POLICY "Service role can manage visits"
ON daily_visits FOR ALL
USING (auth.role() = 'service_role')
WITH CHECK (auth.role() = 'service_role');

-- VCF Generations Policies
DROP POLICY IF EXISTS "Anyone can read VCF generations" ON vcf_generations;
CREATE POLICY "Anyone can read VCF generations"
ON vcf_generations FOR SELECT
USING (status = 'completed');

DROP POLICY IF EXISTS "Service role can manage VCF generations" ON vcf_generations;
CREATE POLICY "Service role can manage VCF generations"
ON vcf_generations FOR ALL
USING (auth.role() = 'service_role')
WITH CHECK (auth.role() = 'service_role');

-- Rate Limits Policies
DROP POLICY IF EXISTS "Service role can manage rate limits" ON rate_limits;
CREATE POLICY "Service role can manage rate limits"
ON rate_limits FOR ALL
USING (auth.role() = 'service_role')
WITH CHECK (auth.role() = 'service_role');

-- Feedback Policies
DROP POLICY IF EXISTS "Anyone can insert feedback" ON feedback;
CREATE POLICY "Anyone can insert feedback"
ON feedback FOR INSERT
WITH CHECK (true);

DROP POLICY IF EXISTS "Service role can manage feedback" ON feedback;
CREATE POLICY "Service role can manage feedback"
ON feedback FOR ALL
USING (auth.role() = 'service_role')
WITH CHECK (auth.role() = 'service_role');

-- Contact Messages Policies
DROP POLICY IF EXISTS "Anyone can insert contact messages" ON contact_messages;
CREATE POLICY "Anyone can insert contact messages"
ON contact_messages FOR INSERT
WITH CHECK (true);

DROP POLICY IF EXISTS "Service role can manage contact messages" ON contact_messages;
CREATE POLICY "Service role can manage contact messages"
